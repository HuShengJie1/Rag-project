    {
      "block_type": "text",
      "text": "$$E_D = \\sum_{i=1}^k \\frac{M_i}{S_i} \\times \\delta_i, \\quad \\sum_{i=1}^k \\delta_i = 1$$\n(4.1)",
      "page_no": 4,
      "metadata": {
        "metadata": {
          "md": "$$E\\_D = \\sum\\_{i=1}^k \\frac{M\\_i}{S\\_i} \\times \\delta\\_i, \\quad \\sum\\_{i=1}^k \\delta\\_i = 1$$\n(4.1)",
          "value": "$$E_D = \\sum_{i=1}^k \\frac{M_i}{S_i} \\times \\delta_i, \\quad \\sum_{i=1}^k \\delta_i = 1$$\n(4.1)",
          "bbox": [
