    {
      "block_type": "text",
      "text": "毕业要求达成情况评价包括直接评价和间接评价。",
      "page_no": 2,
      "metadata": {
        "metadata": {
          "md": "毕业要求达成情况评价包括直接评价和间接评价。",
          "value": "毕业要求达成情况评价包括直接评价和间接评价。",
          "bbox": [
